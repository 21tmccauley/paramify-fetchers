{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Envelope",
  "description": "Standard wrapper the runner places around every JSON evidence file. metadata = facts about the collection; payload = the fetcher's raw output. See docs/envelope_design.md.",
  "type": "object",
  "required": ["schema_version", "metadata", "payload"],
  "properties": {
    "schema_version": { "type": "string" },
    "metadata": {
      "type": "object",
      "required": ["fetcher_name", "fetcher_version", "run_id", "collected_at", "status", "exit_code"],
      "properties": {
        "fetcher_name": { "type": "string" },
        "fetcher_version": { "type": "string" },
        "category": { "type": ["string", "null"] },
        "run_id": { "type": "string" },
        "target": { "type": ["object", "null"] },
        "collected_at": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failed"] },
        "exit_code": { "type": "integer" },
        "error": { "type": "string" },
        "evidence_set": {
          "type": "object",
          "description": "Paramify evidence-set identity copied from the fetcher's fetcher.yaml, so the file is self-describing for upload. Present only when the fetcher declares an evidence_set block.",
          "required": ["reference_id", "name"],
          "properties": {
            "reference_id": { "type": "string" },
            "name": { "type": "string" },
            "instructions": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "payload": {}
  }
}
