# Keep the build context lean and avoid leaking local state into the image.
.git
.github
.venv
venv
evidence/
**/__pycache__
**/*.pyc
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
*_mock.svg
# Never bake secrets or local working files into the image.
.env
.env.*
!.env.example
manifest.yaml
manifests/
