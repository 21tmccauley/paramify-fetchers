# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtualenv ---
.venv/
venv/

# --- Secrets: NEVER commit ---
# The framework resolves ${env:VAR} from the environment; .env is one source
# among many and must stay local.
.env
.env.*
!.env.example

# --- Generated collect output (runner writes evidence/run-<timestamp>/) ---
/evidence/

# --- Local working manifest ---
# The manifest builder writes ./manifest.yaml by default; canonical samples
# live in examples/. Delete this line if you want to commit your own manifest.
/manifest.yaml

# --- Claude Code: ignore personal settings, keep shared skills + settings.json ---
.claude/settings.local.json

# --- macOS / editors ---
.DS_Store
.idea/
.vscode/
*.swp
